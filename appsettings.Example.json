{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "FvCore.Services.ScannerService": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=False;MultipleActiveResultSets=True;"
  },
  "MediaSettings": {
    "RootPath": "wwwroot/multimedia"
  },
  "GoogleDrive": {
    "CredentialsPath": "google-credentials.json",
    "FolderId": "YOUR_GOOGLE_DRIVE_FOLDER_ID"
  }
}
