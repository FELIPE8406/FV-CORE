@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FV-CORE</title>
    <meta name="description" content="FV-CORE Plataforma de Streaming Personal — Interfaz Digital Cyberpunk" />
    <link rel="stylesheet" href="~/css/fvcore.css" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎵</text></svg>" />
</head>
<body>
    <div class="app-layout">
        <!-- ═══ SIDEBAR ═══ -->
        <nav class="sidebar">
            <div class="sidebar-logo">
                <h1>FV-CORE</h1>
                <div class="logo-subtitle">plataforma de streaming</div>
            </div>
            <div class="sidebar-nav">
                <div class="sidebar-section-title">Principal</div>
                <a href="@Url.Action("Index", "Home")" class="sidebar-link @(currentController == "Home" ? "active" : "")">
                    <span class="link-icon">◆</span>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Index", "Artists")" class="sidebar-link @(currentController == "Artists" ? "active" : "")">
                    <span class="link-icon">♫</span>
                    <span>Artistas</span>
                </a>

                <div class="sidebar-section-title">Biblioteca</div>
                <a href="@Url.Action("Music", "Media")" class="sidebar-link @(currentController == "Media" && currentAction == "Music" ? "active" : "")">
                    <span class="link-icon">♪</span>
                    <span>Música</span>
                </a>
                <a href="@Url.Action("Videos", "Media")" class="sidebar-link @(currentController == "Media" && currentAction == "Videos" ? "active" : "")">
                    <span class="link-icon">▶</span>
                    <span>Videos</span>
                </a>

                <div class="sidebar-section-title">Colecciones</div>
                <a href="@Url.Action("Index", "Playlists")" class="sidebar-link @(currentController == "Playlists" ? "active" : "")">
                    <span class="link-icon">☰</span>
                    <span>Playlists</span>
                </a>
                <a href="@Url.Action("Index", "Favorites")" class="sidebar-link @(currentController == "Favorites" ? "active" : "")">
                    <span class="link-icon">♥</span>
                    <span>Favoritos</span>
                </a>
            </div>
            <div class="sidebar-footer">
                FV-CORE <span class="version">v1.0.0</span><br />
                .NET 8 • EF Core
            </div>
        </nav>

        <!-- ═══ MAIN CONTENT ═══ -->
        <main class="main-content">
            @RenderBody()
        </main>

        <!-- ═══ PERSISTENT AUDIO PLAYER ═══ -->
        <div id="player-bar" class="player-bar hidden">
            <img id="player-cover" class="player-cover" src="/images/default-cover.svg" alt="Cover" />
            <div class="player-track-info">
                <div id="player-title" class="player-track-title">Sin pista seleccionada</div>
                <div id="player-artist" class="player-track-artist">—</div>
            </div>
            <div class="player-controls">
                <button id="player-shuffle" class="player-btn" title="Aleatorio: Desactivado" onclick="FvCore.toggleShuffle()">🔀</button>
                <button id="player-prev" class="player-btn" title="Anterior">⏮</button>
                <button id="player-play" class="player-btn play-btn" title="Reproducir/Pausar">▶</button>
                <button id="player-next" class="player-btn" title="Siguiente">⏭</button>
            </div>
            <div class="player-progress">
                <span id="time-current" class="time-display">0:00</span>
                <div id="progress-container" class="progress-bar-container">
                    <div id="progress-fill" class="progress-bar-fill" style="width: 0%;"></div>
                </div>
                <span id="time-total" class="time-display">0:00</span>
            </div>
            <div class="player-volume">
                <span>🔊</span>
                <input type="range" id="volume-slider" class="volume-slider" min="0" max="1" step="0.05" value="0.8" />
            </div>
            <button id="player-fav" class="btn-favorite" title="Favorito">♡</button>
        </div>
    </div>

    <!-- ═══ PLAYLIST CREATE MODAL ═══ -->
    <div id="playlist-modal" class="modal-overlay">
        <div class="modal">
            <h3>// NUEVA PLAYLIST</h3>
            <input type="text" id="playlist-name-input" placeholder="Nombre de la playlist..." maxlength="200" />
            <div class="modal-actions">
                <button id="modal-cancel" class="btn-neon small">Cancelar</button>
                <button id="modal-confirm" class="btn-neon small purple">Crear</button>
            </div>
        </div>
    </div>

    <script src="~/js/fvcore.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
