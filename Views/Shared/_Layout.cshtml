@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] — FV-CORE</title>
    <meta name="description" content="FV-CORE Plataforma de Streaming Personal — Música desde Google Drive" />
    
    <!-- PWA / iOS Support -->
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="FV">
    <link rel="apple-touch-icon" href="/icons/fv-192.png?v=1">
    <meta name="theme-color" content="#000000">

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=JetBrains+Mono:wght@300;400;500;600;700&family=Orbitron:wght@400;500;700;900&display=swap" />
    <link rel="stylesheet" href="~/css/fvcore.css" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎵</text></svg>" />
</head>
<body>
    <div id="app-loader" class="app-loader"></div>
    <div class="app-layout">

        <!-- ═══ SIDEBAR ═══ -->
        <nav class="sidebar">
            <div class="sidebar-logo">
                <h1>FV-CORE</h1>
                <div class="logo-subtitle">plataforma de streaming de pipe</div>
            </div>
            <div class="sidebar-nav">
                <div class="sidebar-section-title">Principal</div>
                <a href="@Url.Action("Index", "Home")" class="sidebar-link @(currentController == "Home" ? "active" : "")">
                    <span class="link-icon">◆</span>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Index", "Artists")" class="sidebar-link @(currentController == "Artists" ? "active" : "")">
                    <span class="link-icon">♫</span>
                    <span>Artistas</span>
                </a>
                <a href="#" class="sidebar-link" id="btn-sync-drive">
                    <span class="link-icon">🔄</span>
                    <span>Sync Drive</span>
                </a>

                <div class="sidebar-section-title">Biblioteca</div>
                <a href="@Url.Action("Music", "Media")" class="sidebar-link @(currentController == "Media" && currentAction == "Music" ? "active" : "")">
                    <span class="link-icon">♪</span>
                    <span>Música</span>
                </a>
                <a href="@Url.Action("Videos", "Media")" class="sidebar-link @(currentController == "Media" && currentAction == "Videos" ? "active" : "")">
                    <span class="link-icon">▶</span>
                    <span>Videos</span>
                </a>

                <div class="sidebar-section-title">Colecciones</div>
                <a href="@Url.Action("Index", "Playlists")" class="sidebar-link @(currentController == "Playlists" ? "active" : "")">
                    <span class="link-icon">☰</span>
                    <span>Playlists</span>
                </a>
                <a href="@Url.Action("Index", "Favorites")" class="sidebar-link @(currentController == "Favorites" ? "active" : "")">
                    <span class="link-icon">♥</span>
                    <span>Favoritos</span>
                </a>
            </div>
            <div class="sidebar-footer">
                Desarrollado por Felipe Valbuena &mdash; PipeSoft
            </div>
        </nav>

        <!-- ═══ MAIN CONTENT ═══ -->
        <main class="main-content">
            @RenderBody()
        </main>

        <!-- ═══ PERSISTENT MINI PLAYER ═══ -->
        <div id="player-bar" class="player-bar hidden">

            <!-- Left zone: cover + info (tap to expand Now Playing) -->
            <div class="player-left" id="player-expand-trigger" title="Abrir reproductor">
                <div class="player-cover-wrap">
                    <img id="player-cover" class="player-cover" src="/images/default-cover.svg" alt="Cover" />
                    <div class="player-cover-eq">
                        <span></span><span></span><span></span>
                    </div>
                </div>
                <div class="player-track-info">
                    <div id="player-title" class="player-track-title">Sin pista seleccionada</div>
                    <div id="player-artist" class="player-track-artist">—</div>
                </div>
            </div>

            <!-- Center zone: transport + progress -->
            <div class="player-center">
                <div class="player-controls">
                    <button id="player-shuffle" class="player-btn shuffle-btn" title="Aleatorio: Desactivado" onclick="FvCore.toggleShuffle()">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/></svg>
                    </button>
                    <button id="player-prev" class="player-btn" title="Anterior">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
                    </button>
                    <button id="player-play" class="player-btn play-btn" title="Reproducir/Pausar">
                        <svg id="play-icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                        <svg id="pause-icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                    </button>
                    <button id="player-next" class="player-btn" title="Siguiente">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
                    </button>
                    <button id="player-repeat" class="player-btn repeat-btn" title="Repetir: Desactivado">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/></svg>
                    </button>
                </div>
                <div class="player-progress">
                    <span id="time-current" class="time-display">0:00</span>
                    <div id="progress-container" class="progress-bar-container">
                        <div id="progress-fill" class="progress-bar-fill" style="width: 0%;"></div>
                    </div>
                    <span id="time-total" class="time-display">0:00</span>
                </div>
            </div>

            <!-- Right zone: volume + secondary actions -->
            <div class="player-right">
                <div class="player-volume">
                    <svg class="vol-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
                    <input type="range" id="volume-slider" class="volume-slider" min="0" max="1" step="0.05" value="0.8" />
                </div>
                <div class="player-actions">
                    <button id="player-queue-btn" class="player-btn" title="Ver Cola">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
                    </button>
                    <a id="player-download" class="player-btn" title="Descargar archivo" href="#" download>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
                    </a>
                    <button id="player-fav" class="btn-favorite" title="Favorito">
                        <svg id="fav-icon-empty" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 3c-1.74 0-3.41.81-4.5 2.09C10.91 3.81 9.24 3 7.5 3 4.42 3 2 5.42 2 8.5c0 3.78 3.4 6.86 8.55 11.54L12 21.35l1.45-1.32C18.6 15.36 22 12.28 22 8.5 22 5.42 19.58 3 16.5 3zm-4.4 15.55l-.1.1-.1-.1C7.14 14.24 4 11.39 4 8.5 4 6.5 5.5 5 7.5 5c1.54 0 3.04.99 3.57 2.36h1.87C13.46 5.99 14.96 5 16.5 5c2 0 3.5 1.5 3.5 3.5 0 2.89-3.14 5.74-7.9 10.05z"/></svg>
                        <svg id="fav-icon-filled" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    </button>
                    <button id="player-expand-btn" class="player-btn expand-btn" title="Abrir reproductor">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z"/></svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- ═══ LOCAL QUEUE MODAL ═══ -->
        <div id="queue-modal" class="modal-overlay">
            <div class="modal queue-modal">
                <h3>// COLA DE REPRODUCCIÓN</h3>
                <div id="queue-list" class="queue-list"></div>
                <div class="modal-actions">
                    <button id="btn-clear-queue" class="btn-neon small red">Limpiar Cola</button>
                    <button id="btn-close-queue" class="btn-neon small">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ PLAYLIST CREATE MODAL (outside app-layout) ═══ -->
    <div id="playlist-modal" class="modal-overlay">
        <div class="modal">
            <h3>// NUEVA PLAYLIST</h3>
            <input type="text" id="playlist-name-input" placeholder="Nombre de la playlist..." maxlength="200" />
            <div class="modal-actions">
                <button id="modal-cancel" class="btn-neon small">Cancelar</button>
                <button id="modal-confirm" class="btn-neon small purple">Crear</button>
            </div>
        </div>
    </div>

    <!-- ═══ NOW PLAYING PANEL + CONTEXT MENU injected by fvcore.js ═══ -->

    <script src="~/js/fvcore.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
