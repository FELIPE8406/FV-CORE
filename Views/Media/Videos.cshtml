@model IEnumerable<FvCore.Models.MediaItem>
@{
    ViewData["Title"] = "Videos";
    var page = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var totalItems = ViewBag.TotalItems != null ? (int)ViewBag.TotalItems : 0;
}

<div class="page-header" style="display:flex; justify-content:space-between; align-items:flex-start;">
    <div>
        <h2>VIDEOS</h2>
        <div class="page-subtitle">@totalItems.ToString("N0") videos en la biblioteca</div>
    </div>
    <button class="btn-neon small" onclick="window.history.back()">← Volver</button>
</div>

<form method="get" class="search-bar">
    <input type="text" name="search" id="search-input" value="@ViewBag.Search"
           placeholder="Buscar videos..." autocomplete="off" />
    <button type="submit">⌕</button>
</form>

<!-- Inline Video Player -->
<div id="video-player-container" class="video-player-container">
    <button class="video-close">✕ CERRAR</button>
    <video controls id="video-element"></video>
</div>

@if (Model.Any())
{
    <div class="video-grid">
        @foreach (var video in Model)
        {
            <div class="video-card" data-video-id="@video.Id" data-title="@video.Titulo">
                <div class="video-thumb">
                    🎬
                    <div class="play-overlay">
                        <span style="font-size: 3rem; color: var(--neon-purple);">▶</span>
                    </div>
                </div>
                <div class="video-info">
                    <div class="video-title" title="@video.Titulo">@video.Titulo</div>
                    <div class="video-meta">
                        <span>@(video.AlbumName ?? "—")</span>
                        <span style="color: var(--neon-purple);">@(video.Calidad ?? "SD")</span>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="pagination">
            @if (page > 1)
            {
                <a href="@Url.Action("Videos", "Media", new { search = ViewBag.Search, page = page - 1 })">← Anterior</a>
            }

            @for (int p = Math.Max(1, page - 3); p <= Math.Min(totalPages, page + 3); p++)
            {
                if (p == page)
                {
                    <span class="current">@p</span>
                }
                else
                {
                    <a href="@Url.Action("Videos", "Media", new { search = ViewBag.Search, page = p })">@p</a>
                }
            }

            @if (page < totalPages)
            {
                <a href="@Url.Action("Videos", "Media", new { search = ViewBag.Search, page = page + 1 })">Siguiente →</a>
            }
        </div>
    }
}
else
{
    <div class="empty-state">
        <div class="empty-icon">▶</div>
        <div class="empty-text">No se encontraron videos</div>
        <div class="empty-hint">Los videos de la carpeta Películas aparecerán aquí</div>
    </div>
}
