@model IEnumerable<FvCore.Controllers.VideoFolderViewModel>
@{
    ViewData["Title"] = "Videos — Carpetas";
    int page       = ViewBag.Page       != null ? (int)ViewBag.Page       : 1;
    int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    int totalItems = ViewBag.TotalItems != null ? (int)ViewBag.TotalItems : 0;
}

<div class="page-header" style="display:flex; justify-content:space-between; align-items:flex-start;">
    <div>
        <h2 style="color: var(--neon-green, #00FF00); letter-spacing: 2px;">VIDEOS</h2>
        <div class="page-subtitle">@totalItems carpetas en la biblioteca</div>
    </div>
    <button class="btn-neon small" onclick="window.history.back()">← Volver</button>
</div>

<form method="get" class="search-bar">
    <input type="text" name="search" id="search-input" value="@ViewBag.Search"
           placeholder="Buscar carpetas de video..." autocomplete="off" />
    <button type="submit">⌕</button>
</form>

@if (Model != null && Model.Any())
{
    <div style="display: grid;
                grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
                gap: 22px;
                padding: 24px 0;">

        @foreach (var folder in Model)
        {
            <a href="@Url.Action("VideoFolder", "Media", new { folderName = folder.FolderName })"
               style="text-decoration: none; color: inherit;">

                <div style="background: rgba(15,15,15,0.9);
                            border: 1px solid rgba(0,255,0,0.15);
                            border-radius: 10px;
                            padding: 20px 16px;
                            text-align: center;
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            gap: 10px;
                            cursor: pointer;
                            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;"
                     onmouseover="this.style.transform='translateY(-6px)';
                                  this.style.boxShadow='0 6px 20px rgba(0,255,0,0.25)';
                                  this.style.borderColor='rgba(0,255,0,0.6)';"
                     onmouseout ="this.style.transform='translateY(0)';
                                  this.style.boxShadow='none';
                                  this.style.borderColor='rgba(0,255,0,0.15)';">

                    <div style="font-size: 3.5rem; line-height: 1;">🎬</div>

                    <div style="font-weight: 700;
                                font-size: 0.95rem;
                                color: #ffffff;
                                white-space: nowrap;
                                overflow: hidden;
                                text-overflow: ellipsis;
                                width: 100%;
                                letter-spacing: 0.5px;"
                         title="@folder.FolderName">
                        @folder.FolderName
                    </div>

                    <div style="font-size: 0.78rem;
                                color: var(--neon-green, #00FF00);
                                font-family: monospace;
                                letter-spacing: 1px;">
                        @folder.VideoCount @(folder.VideoCount == 1 ? "video" : "videos")
                    </div>
                </div>
            </a>
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="pagination">
            @if (page > 1)
            {
                <a href="@Url.Action("Videos", "Media", new { search = ViewBag.Search, page = page - 1 })">← Anterior</a>
            }
            @for (int p = Math.Max(1, page - 3); p <= Math.Min(totalPages, page + 3); p++)
            {
                if (p == page)
                {
                    <span class="current">@p</span>
                }
                else
                {
                    <a href="@Url.Action("Videos", "Media", new { search = ViewBag.Search, page = p })">@p</a>
                }
            }
            @if (page < totalPages)
            {
                <a href="@Url.Action("Videos", "Media", new { search = ViewBag.Search, page = page + 1 })">Siguiente →</a>
            }
        </div>
    }
}
else
{
    <div class="empty-state">
        <div class="empty-icon">📁</div>
        <div class="empty-text">No se encontraron carpetas de video</div>
        <div class="empty-hint">Sincroniza tu Google Drive para que aparezcan aquí</div>
    </div>
}
