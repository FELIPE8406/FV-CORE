@model IEnumerable<FvCore.Models.MediaItem>
@{
    ViewData["Title"] = "Música";
    var genres = ViewBag.Genres as List<string>;
    var currentGenre = ViewBag.Genre as string;
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var totalItems = (int)ViewBag.TotalItems;
}

<div class="page-header">
    <h2>MÚSICA</h2>
    <div class="page-subtitle">@totalItems.ToString("N0") pistas en la biblioteca</div>
</div>

<form method="get" class="search-bar">
    <input type="text" name="search" id="search-input" value="@ViewBag.Search"
           placeholder="Buscar pistas o artistas..." autocomplete="off" />
    <input type="hidden" name="genre" value="@currentGenre" />
    <button type="submit">⌕</button>
</form>

<!-- Genre Filter -->
@if (genres != null && genres.Any())
{
    <div class="genre-filters">
        <a href="@Url.Action("Music", "Media", new { search = ViewBag.Search })"
           class="genre-pill @(string.IsNullOrEmpty(currentGenre) ? "active" : "")">Todos</a>
        @foreach (var genre in genres)
        {
            <a href="@Url.Action("Music", "Media", new { search = ViewBag.Search, genre = genre })"
               class="genre-pill @(currentGenre == genre ? "active" : "")">@genre</a>
        }
    </div>
}

@if (Model.Any())
{
    <div style="margin-bottom: 16px;">
        <button class="btn-neon shuffle-btn" onclick="FvCore.shufflePlay()">
            🔀 REPRODUCCIÓN ALEATORIA
        </button>
    </div>
    <table class="track-list" id="music-track-list">
        <thead>
            <tr>
                <th class="track-select-cell">
                    <input type="checkbox" class="track-checkbox" id="select-all-music" title="Seleccionar todo" />
                </th>
                <th>#</th>
                <th>Título</th>
                <th>Artista</th>
                <th>Álbum</th>
                <th>Género</th>
                <th>Calidad</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @{ int idx = (page - 1) * 50; }
            @foreach (var track in Model)
            {
                idx++;
                <tr data-track-id="@track.Id"
                    data-title="@track.Titulo"
                    data-artist="@(track.Artist?.Nombre ?? "Desconocido")"
                    data-cover-id="@track.Id">
                    <td class="track-select-cell">
                        <input type="checkbox" class="track-checkbox track-select-cb" data-id="@track.Id" />
                    </td>
                    <td class="track-number">@idx</td>
                    <td>
                        <div class="track-title-cell">
                            <img class="track-cover" src="/cover/@track.Id" alt="" loading="lazy" />
                            <div class="track-info">
                                <div class="track-title">@track.Titulo</div>
                            </div>
                        </div>
                    </td>
                    <td class="track-artist">@(track.Artist?.Nombre ?? "—")</td>
                    <td style="font-size: 0.75rem; color: var(--text-secondary);">@(track.AlbumName ?? "—")</td>
                    <td><span class="track-genre">@(track.Genero ?? "—")</span></td>
                    <td class="track-quality">@(track.Calidad ?? "—")</td>
                    <td>
                        <div class="track-actions">
                            <button class="btn-quick-add" data-media-id="@track.Id" title="Agregar a playlist">+</button>
                            <button class="btn-favorite @(track.IsFavorite ? "active" : "")"
                                    data-media-id="@track.Id" title="Favorito">
                                @(track.IsFavorite ? "♥" : "♡")
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="pagination">
            @if (page > 1)
            {
                <a href="@Url.Action("Music", "Media", new { search = ViewBag.Search, genre = currentGenre, page = page - 1 })">← Anterior</a>
            }

            @for (int p = Math.Max(1, page - 3); p <= Math.Min(totalPages, page + 3); p++)
            {
                if (p == page)
                {
                    <span class="current">@p</span>
                }
                else
                {
                    <a href="@Url.Action("Music", "Media", new { search = ViewBag.Search, genre = currentGenre, page = p })">@p</a>
                }
            }

            @if (page < totalPages)
            {
                <a href="@Url.Action("Music", "Media", new { search = ViewBag.Search, genre = currentGenre, page = page + 1 })">Siguiente →</a>
            }
        </div>
    }
}
else
{
    <div class="empty-state">
        <div class="empty-icon">♪</div>
        <div class="empty-text">No se encontraron pistas</div>
        <div class="empty-hint">Intenta ajustar tu búsqueda o filtro de género</div>
    </div>
}

<!-- Floating Selection Bar -->
<div id="selection-bar" class="selection-bar">
    <div class="selection-count"><span id="selection-count-num">0</span> pistas seleccionadas</div>
    <button class="btn-add-to-playlist" id="btn-open-playlist-picker">☰ AGREGAR A PLAYLIST</button>
    <button class="btn-clear-selection" id="btn-clear-selection">✕ Limpiar</button>
</div>

<!-- Playlist Picker Modal -->
<div id="playlist-picker-modal" class="modal-overlay playlist-picker-modal">
    <div class="modal">
        <h3>SELECCIONAR PLAYLIST</h3>
        <div class="playlist-picker-divider">Tus playlists</div>
        <div id="playlist-picker-list" class="playlist-picker-list">
            <!-- Populated via JS -->
        </div>
        <div class="playlist-picker-divider">Crear nueva</div>
        <div class="playlist-picker-create">
            <input type="text" id="picker-new-name" placeholder="Nombre de la playlist..." />
            <button class="btn-neon small" id="picker-create-btn">Crear</button>
        </div>
        <div class="modal-actions" style="margin-top: 16px;">
            <button class="btn-neon small" id="picker-cancel-btn">Cancelar</button>
        </div>
    </div>
</div>
