@model IEnumerable<FvCore.Models.MediaItem>
@{
    ViewData["Title"] = "Música";
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var totalItems = (int)ViewBag.TotalItems;
}

<div class="music-hero">
    <div class="music-hero-inner">
        <h1 class="music-hero-title">Explora tu música</h1>
        <p class="music-hero-subtitle">@totalItems.ToString("N0") pistas en tu biblioteca personal</p>
        
        <form method="get" class="music-search-form">
            <div class="music-search-wrapper">
                <span class="music-search-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                </span>
                <input type="text" name="search" id="search-input" value="@ViewBag.Search"
                       placeholder="Buscar canciones, artistas..." autocomplete="off" class="music-search-input" />
                @if (!string.IsNullOrEmpty(ViewBag.Search))
                {
                    <a href="@Url.Action("Music", "Media")" class="music-search-clear" title="Limpiar búsqueda">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </a>
                }
            </div>
        </form>
    </div>
</div>

@{
    var safeModel = Model ?? new List<FvCore.Models.MediaItem>();
}
<script>
    if (!Array.isArray(window.__GLOBAL_TRACK_STORE)) {
        window.__GLOBAL_TRACK_STORE = [];
    }

    window.__GLOBAL_TRACK_STORE = @Html.Raw(
        System.Text.Json.JsonSerializer.Serialize(
            safeModel.Select(x => {
                var albumFirstTrack = safeModel.FirstOrDefault(m => m.AlbumName == x.AlbumName && !string.IsNullOrEmpty(m.CoverPath));
                return new {
                    id = x.Id.ToString(),
                    title = string.IsNullOrWhiteSpace(x.Titulo) ? "Unknown" : x.Titulo,
                    artist = string.IsNullOrWhiteSpace(x.ArtistName) ? "Unknown" : x.ArtistName,
                    album = string.IsNullOrWhiteSpace(x.AlbumName) ? "Unknown" : x.AlbumName,
                    genre = x.Genero ?? "Unknown",
                    quality = x.Calidad ?? "Unknown",
                    coverId = (x.CoverPath != null ? x.Id : (albumFirstTrack?.Id ?? x.Id)).ToString()
                };
            })
        )
    );
</script>

@if (safeModel.Any())
{

    <div style="margin-bottom: 24px; display: flex; justify-content: flex-start; align-items: center;">
        <button class="btn-neon shuffle-btn" onclick="if(window.FvCore) FvCore.shufflePlay()">
            🔀 REPRODUCCIÓN ALEATORIA
        </button>
    </div>
    
    <div id="music-track-list">
        @{ int globalIndexOffset = (page - 1) * 50; }
        @foreach (var albumGroup in safeModel.GroupBy(m => new { 
            Album = string.IsNullOrWhiteSpace(m.AlbumName) ? "Unknown" : m.AlbumName, 
            Artist = string.IsNullOrWhiteSpace(m.ArtistName) ? "Unknown" : m.ArtistName 
        }))
        {
            string hash = Guid.NewGuid().ToString("N").Substring(0, 8);
            var firstTrack = albumGroup.FirstOrDefault(m => !string.IsNullOrEmpty(m.CoverPath)) ?? albumGroup.First();
            int trackCount = albumGroup.Count();
            
            string displayAlbum = string.Equals(albumGroup.Key.Album?.Trim(), "Unknown", StringComparison.OrdinalIgnoreCase) ? "Sencillos" : albumGroup.Key.Album;
            string displayArtist = string.Equals(albumGroup.Key.Artist?.Trim(), "Unknown", StringComparison.OrdinalIgnoreCase) ? "" : albumGroup.Key.Artist;
            
            <div class="album-accordion-header ui-glass-card" data-album="@albumGroup.Key.Album" data-artist="@albumGroup.Key.Artist" data-body-id="body-@hash" data-offset="@globalIndexOffset">
                <div class="album-accordion-info">
                    <img class="album-accordion-cover" src="/cover/@firstTrack.Id" alt="" loading="lazy" />
                    <div class="album-accordion-text">
                        <div class="album-accordion-title">@displayAlbum</div>
                        @if(!string.IsNullOrEmpty(displayArtist))
                        {
                            <div class="album-accordion-artist">@displayArtist</div>
                        }
                    </div>
                </div>
                <div class="album-accordion-meta">
                    <a class="btn-neon small" style="margin-right: 12px;" href="@Url.Action("DownloadAlbum", "Streaming", new { trackId = firstTrack.Id })" onclick="event.stopPropagation();">⬇ Descargar Álbum</a>
                    <div class="album-accordion-count">@trackCount pistas</div>
                    <svg class="album-accordion-chevron" viewBox="0 0 24 24">
                        <path d="M6 9l6 6 6-6"/>
                    </svg>
                </div>
            </div>
            
            <div class="album-accordion-body" id="body-@hash" data-loaded="false">
                <!-- Lazy rendered via JS -->
            </div>
            globalIndexOffset += trackCount;
        }
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="pagination">
            @if (page > 1)
            {
                <a href="@Url.Action("Music", "Media", new { search = ViewBag.Search, page = page - 1 })">← Anterior</a>
            }

            @for (int p = Math.Max(1, page - 3); p <= Math.Min(totalPages, page + 3); p++)
            {
                if (p == page)
                {
                    <span class="current">@p</span>
                }
                else
                {
                    <a href="@Url.Action("Music", "Media", new { search = ViewBag.Search, page = p })">@p</a>
                }
            }

            @if (page < totalPages)
            {
                <a href="@Url.Action("Music", "Media", new { search = ViewBag.Search, page = page + 1 })">Siguiente →</a>
            }
        </div>
    }
}
else
{
    <div class="empty-state">
        <div class="empty-icon">♪</div>
        <div class="empty-text">No se encontraron pistas</div>
        <div class="empty-hint">Intenta ajustar tu búsqueda</div>
    </div>
}

<!-- Floating Selection Bar -->
<div id="selection-bar" class="selection-bar">
    <div class="selection-count"><span id="selection-count-num">0</span> pistas seleccionadas</div>
    <button class="btn-add-to-playlist" id="btn-open-playlist-picker">☰ AGREGAR A PLAYLIST</button>
    <button class="btn-clear-selection" id="btn-clear-selection">✕ Limpiar</button>
</div>

<!-- Playlist Picker Modal -->
<div id="playlist-picker-modal" class="modal-overlay playlist-picker-modal">
    <div class="modal">
        <h3>SELECCIONAR PLAYLIST</h3>
        <div class="playlist-picker-divider">Tus playlists</div>
        <div id="playlist-picker-list" class="playlist-picker-list">
            <!-- Populated via JS -->
        </div>
        <div class="playlist-picker-divider">Crear nueva</div>
        <div class="playlist-picker-create">
            <input type="text" id="picker-new-name" placeholder="Nombre de la playlist..." />
            <button class="btn-neon small" id="picker-create-btn">Crear</button>
        </div>
        <div class="modal-actions" style="margin-top: 16px;">
            <button class="btn-neon small" id="picker-cancel-btn">Cancelar</button>
        </div>
    </div>
</div>
